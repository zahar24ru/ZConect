# Копируйте в .env и подставьте свои значения.
# Файл .env не коммитится в git.
#
# На VPS обязательно укажите реальный внешний IP в PUBLIC_IPV4,
# иначе TURN не будет работать для клиентов из интернета.

APP_ENV=prod
SIGNALING_PORT=8080
REDIS_ADDR=redis:6379
SESSION_TTL_SEC=300
MAX_JOIN_ATTEMPTS=5
LOCK_MINUTES=10
TURN_REALM=zconect.local
TURN_USER=zconect
TURN_PASS=change_me
# Для VPS подставьте ваш публичный IPv4 (не 127.0.0.1):
PUBLIC_IPV4=127.0.0.1
