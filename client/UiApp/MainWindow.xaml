<Window x:Class="UiApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ZConnect"
        Height="600"
        Width="520"
        MinWidth="500"
        MinHeight="520"
        Background="#F3F7FC"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="12"
                Background="#FFFFFF"
                BorderBrush="#D7E2EF"
                BorderThickness="1"
                Padding="4"
                Margin="0,0,0,10">
            <Menu Background="Transparent">
                <MenuItem Header="Настройки">
                    <MenuItem Header="Система" Click="MenuSystem_Click"/>
                    <Separator/>
                    <MenuItem Header="Выход" Click="MenuExit_Click"/>
                </MenuItem>
                <MenuItem Header="Инструменты">
                    <MenuItem Header="Заглушка" Click="MenuToolsStub1_Click"/>
                    <MenuItem Header="Заглушка" Click="MenuToolsStub2_Click"/>
                </MenuItem>
                <MenuItem Header="О программе">
                    <MenuItem Header="Справка" Click="MenuHelp_Click"/>
                    <MenuItem Header="Логи" Click="MenuLogs_Click"/>
                </MenuItem>
            </Menu>
        </Border>

        <Border Grid.Row="1"
                CornerRadius="14"
                BorderBrush="#D7E2EF"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F9FCFF" Offset="0"/>
                    <GradientStop Color="#EAF3FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="ZConnect"
                       FontSize="23"
                       FontWeight="SemiBold"
                       Foreground="#155FA2"/>
        </Border>

        <Border Grid.Row="2"
                CornerRadius="14"
                Background="#FFFFFF"
                BorderBrush="#D7E2EF"
                BorderThickness="1"
                Padding="14"
                Margin="0,0,0,10">
            <TabControl>
                <TabItem Header="Создать сессию">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0"
                                Height="36"
                                Content="Создать сессию"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CreateSessionCommand}"/>

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,4"
                                   Text="Логин / пароль для клиента (только копирование)"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Height="36"
                                     Style="{StaticResource ReadOnlyTextBoxStyle}"
                                     Text="{Binding LoginCode}"/>
                            <TextBox Grid.Column="2"
                                     Height="36"
                                     Style="{StaticResource ReadOnlyTextBoxStyle}"
                                     Text="{Binding PassCode}"/>
                        </Grid>

                        <Button Grid.Row="3"
                                Margin="0,10,0,0"
                                Height="36"
                                Width="170"
                                HorizontalAlignment="Left"
                                Content="Скопировать оба"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CopySessionCodesCommand}"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Подключиться">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Введите логин и пароль, затем подключитесь"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <Grid Grid.Row="1" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <TextBox x:Name="JoinLoginBox"
                                         Height="36"
                                         Style="{StaticResource RoundedTextBoxStyle}"
                                         Text="{Binding JoinLoginCode, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Логин (8 цифр)"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="#9CA3AF"
                                           FontSize="13"
                                           Visibility="{Binding JoinLoginCode, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                            </Grid>
                            <Grid Grid.Column="2">
                                <TextBox x:Name="JoinPassBox"
                                         Height="36"
                                         Style="{StaticResource RoundedTextBoxStyle}"
                                         Text="{Binding JoinPassCode, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Text="Пароль (8 цифр)"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0"
                                           Foreground="#9CA3AF"
                                           FontSize="13"
                                           Visibility="{Binding JoinPassCode, Converter={StaticResource EmptyToVisibilityConverter}}"/>
                            </Grid>
                        </Grid>

                        <Button Grid.Row="2"
                                Height="36"
                                Margin="0,10,0,0"
                                Content="Подключиться"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding JoinSessionCommand}"/>

                        <Button Grid.Row="3"
                                Height="36"
                                Margin="0,10,0,0"
                                Content="Отправить файл"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SendFileCommand}"/>

                        <Border Grid.Row="4"
                                Margin="0,8,0,0"
                                CornerRadius="8"
                                Background="#F6FAFF"
                                BorderBrush="#DDE8F5"
                                BorderThickness="1"
                                Padding="8">
                            <TextBlock Text="{Binding FileTransferProgressText}"
                                       Foreground="#42586E"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="3"
                CornerRadius="14"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="12">
            <StackPanel>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextPrimaryBrush}"/>
                <Expander Header="ICE debug" IsExpanded="False" Margin="0,6,0,0">
                    <StackPanel Margin="0,6,0,0">
                        <TextBlock Text="{Binding IcePathText}"
                                   FontSize="11"
                                   Foreground="{Binding IcePathBrush}"/>
                        <TextBlock Text="Последние 5 кандидатов:"
                                   Margin="0,8,0,0"
                                   FontSize="10"
                                   Foreground="#506377"/>
                        <TextBlock Text="{Binding IceRecentCandidatesText}"
                                   Margin="0,2,0,0"
                                   FontSize="10"
                                   FontFamily="Consolas"
                                   Foreground="#506377"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>
    </Grid>
</Window>
